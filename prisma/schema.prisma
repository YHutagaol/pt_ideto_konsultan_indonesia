generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql" 
  url      = env("DATABASE_URL")
}

model Layanan {
  id          Int           @id @default(autoincrement())
  slug        String        @unique
  title       String
  description String        @db.Text
  icon        String?
  order       Int           @default(0)
  isActive    Boolean       @default(true)
  items       LayananItem[]
}

model LayananItem {
  id        Int     @id @default(autoincrement())
  label     String
  order     Int     @default(0)
  layananId Int
  layanan   Layanan @relation(fields: [layananId], references: [id], onDelete: Cascade)
}

model Program {
  id              Int           @id @default(autoincrement())
  slug            String        @unique
  title           String
  description     String        @db.Text
  icon            String?
  isBnspCertified Boolean       @default(false)
  order           Int           @default(0)
  isActive        Boolean       @default(true)
  items           ProgramItem[]
}

model ProgramItem {
  id        Int     @id @default(autoincrement())
  label     String
  order     Int     @default(0)
  programId Int
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
}

enum KontakStatus {
  BARU
  DIPROSES
  SELESAI
}

model Kontak {
  id              Int          @id @default(autoincrement())
  name            String
  email           String
  phone           String
  subject         String
  message         String       @db.Text
  serviceCategory String?
  status          KontakStatus @default(BARU)
  createdAt       DateTime     @default(now())
}

model Portfolio {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  partner     String
  year        String
  description String   @db.Text
  imageUrl    String?
  gallery     String?  @db.Text
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}